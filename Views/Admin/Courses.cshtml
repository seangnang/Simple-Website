@model IEnumerable<SimpleWebsite.Models.Course>
@{
    ViewData["Title"] = "Course Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">Course Management</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active">Courses</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-primary rounded">
                        <i class="ti ti-book fs-4 text-primary"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Total Courses</p>
                        <h4 class="fw-bold mb-0">@Model.Count()</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-success rounded">
                        <i class="ti ti-eye fs-4 text-success"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Published</p>
                        <h4 class="fw-bold mb-0">@Model.Count(c => c.IsPublished)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-warning rounded">
                        <i class="ti ti-eye-off fs-4 text-warning"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Drafts</p>
                        <h4 class="fw-bold mb-0">@Model.Count(c => !c.IsPublished)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-danger rounded">
                        <i class="ti ti-users fs-4 text-danger"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Total Enrollments</p>
                        <h4 class="fw-bold mb-0">@Model.Sum(c => c.Enrollments.Count)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Courses Table -->
    <div class="card">
        <div class="card-body p-0">
            <div class="p-3 border-bottom">
                <h6 class="fw-semibold mb-0">
                    <i class="ti ti-book me-2"></i>All Courses
                </h6>
            </div>
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Course</th>
                        <th>Instructor</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Lessons</th>
                        <th>Students</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(course.Thumbnail) ? "https://via.placeholder.com/50x50?text=C" : course.Thumbnail)"
                                         style="width:50px; height:50px; object-fit:cover; border-radius:8px;" />
                                    <div>
                                        <p class="fw-semibold mb-0">@course.Title</p>
                                        <small class="text-muted">
                                            @course.CreatedAt.ToString("MMM dd, yyyy")
                                        </small>
                                    </div>
                                </div>
                            </td>
                            <td class="align-middle">
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(course.Instructor?.ProfilePicture))
                                    {
                                        <img src="@course.Instructor.ProfilePicture"
                                             class="rounded-circle"
                                             style="width:30px; height:30px; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-light-primary d-flex align-items-center
                                                                    justify-content-center"
                                             style="width:30px; height:30px;">
                                            <i class="ti ti-user text-primary small"></i>
                                        </div>
                                    }
                                    <span class="small">@course.Instructor?.Fullname</span>
                                </div>
                            </td>
                            <td class="align-middle">
                                @if (course.Category != null)
                                {
                                    <span class="badge bg-light-primary text-primary">
                                        @course.Category.Name
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">None</span>
                                }
                            </td>
                            <td class="align-middle fw-semibold">
                                @(course.Price == 0 ? "Free" : "$" + course.Price.ToString("0.00"))
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-light-primary text-primary">
                                    @course.Lessons.Count
                                </span>
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-light-success text-success">
                                    @course.Enrollments.Count
                                </span>
                            </td>
                            <td class="align-middle">
                                @if (course.IsPublished)
                                {
                                    <span class="badge bg-success">Published</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Draft</span>
                                }
                            </td>
                            <td class="align-middle">
                                <div class="d-flex gap-2">
                                    <a asp-controller="Course" asp-action="Details"
                                       asp-route-id="@course.CourseId"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="ti ti-eye"></i>
                                    </a>
                                    <form asp-action="TogglePublish" method="post">
                                        <input type="hidden" name="id" value="@course.CourseId" />
                                        <button type="submit"
                                                class="btn btn-sm @(course.IsPublished ? "btn-outline-warning" : "btn-outline-success")">
                                            <i class="ti ti-@(course.IsPublished ? "eye-off" : "eye")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="DeleteCourse" method="post"
                                          onsubmit="return confirm('Delete this course?')">
                                        <input type="hidden" name="id" value="@course.CourseId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="ti ti-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>