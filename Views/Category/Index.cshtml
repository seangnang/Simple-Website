@model IEnumerable<SimpleWebsite.Models.Categories>
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">Course Categories</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Categories</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Add Category Form -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">
                        <i class="ti ti-plus me-2"></i>Add New Category
                    </h6>
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Category Name</label>
                            <input name="Name" class="form-control" placeholder="e.g. Web Development" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="Description" class="form-control" rows="3"
                                      placeholder="Brief description..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Icon Class</label>
                            <input name="Icon" class="form-control" placeholder="ti ti-code" />
                            <small class="text-muted">Use Tabler icons e.g. ti ti-code, ti ti-brush</small>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ti ti-plus me-1"></i>Add Category
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Categories List -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <h6 class="fw-semibold mb-0">
                            <i class="ti ti-category me-2"></i>All Categories
                            <span class="badge bg-light-primary text-primary ms-2">@Model.Count()</span>
                        </h6>
                    </div>
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="ti ti-category fs-1 text-muted"></i>
                            <p class="mt-2 text-muted">No categories yet.</p>
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Icon</th>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Courses</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cat in Model)
                                {
                                    <tr>
                                        <td><i class="@cat.Icon fs-4 text-primary"></i></td>
                                        <td class="fw-semibold">@cat.Name</td>
                                        <td class="text-muted small">@cat.Description</td>
                                        <td>
                                            <span class="badge bg-light-primary text-primary">
                                                @cat.Courses.Count
                                            </span>
                                        </td>
                                        <td>
                                            <a asp-action="Edit" asp-route-id="@cat.CategoryId"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="ti ti-edit"></i>
                                            </a>
                                            <form asp-action="Delete" method="post"
                                                  onsubmit="return confirm('Delete this category?')">
                                                <input type="hidden" name="id" value="@cat.CategoryId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="ti ti-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>