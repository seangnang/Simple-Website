@model SimpleWebsite.Models.Coupon
@{
    ViewData["Title"] = "Edit Coupon";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">Edit Coupon</h4>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="CouponId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Coupon Code</label>
                            <input asp-for="Code" class="form-control text-uppercase" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Discount %</label>
                            <input asp-for="DiscountPercent" type="number" class="form-control"
                                   min="1" max="100" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Expiry Date</label>
                            <input asp-for="ExpiryDate" type="date" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Max Uses</label>
                            <input asp-for="MaxUses" type="number" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label class="form-check-label fw-semibold">Active</label>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>