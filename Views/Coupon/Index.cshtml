@model IEnumerable<SimpleWebsite.Models.Coupon>
@{
    ViewData["Title"] = "Coupons";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">Coupon Management</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Coupons</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Create Coupon Form -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">
                        <i class="ti ti-ticket me-2"></i>Create Coupon
                    </h6>
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Coupon Code</label>
                            <input name="Code" class="form-control text-uppercase"
                                   placeholder="e.g. SAVE20" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Discount %</label>
                            <input name="DiscountPercent" type="number" class="form-control"
                                   min="1" max="100" placeholder="e.g. 20" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Expiry Date</label>
                            <input name="ExpiryDate" type="date" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Max Uses</label>
                            <input name="MaxUses" type="number" class="form-control"
                                   min="1" placeholder="100" value="100" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ti ti-plus me-1"></i>Create Coupon
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Coupons List -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <h6 class="fw-semibold mb-0">
                            <i class="ti ti-ticket me-2"></i>All Coupons
                            <span class="badge bg-light-primary text-primary ms-2">@Model.Count()</span>
                        </h6>
                    </div>
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="ti ti-ticket fs-1 text-muted"></i>
                            <p class="mt-2 text-muted">No coupons yet.</p>
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Code</th>
                                    <th>Discount</th>
                                    <th>Used</th>
                                    <th>Expiry</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var coupon in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-light-primary text-primary fs-6">
                                                @coupon.Code
                                            </span>
                                        </td>
                                        <td class="fw-bold text-success">@coupon.DiscountPercent%</td>
                                        <td>@coupon.UsedCount / @coupon.MaxUses</td>
                                        <td>
                                            @if (coupon.ExpiryDate < DateTime.UtcNow)
                                            {
                                                <span class="text-danger small">Expired @coupon.ExpiryDate.ToString("MMM dd, yyyy")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">@coupon.ExpiryDate.ToString("MMM dd, yyyy")</span>
                                            }
                                        </td>
                                        <td>
                                            @if (coupon.IsActive && coupon.ExpiryDate >= DateTime.UtcNow)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a asp-action="Edit" asp-route-id="@coupon.CouponId"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="ti ti-edit"></i>
                                                </a>
                                                <form asp-action="Toggle" method="post">
                                                    <input type="hidden" name="id" value="@coupon.CouponId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                                        <i class="ti ti-@(coupon.IsActive ? "eye-off" : "eye")"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="Delete" method="post"
                                                      onsubmit="return confirm('Delete this coupon?')">
                                                    <input type="hidden" name="id" value="@coupon.CouponId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="ti ti-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>