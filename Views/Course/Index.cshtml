@model IEnumerable<SimpleWebsite.Models.Course>
@{
    ViewData["Title"] = "All Courses";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">All Courses</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Courses</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Search Courses</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="ti ti-search"></i></span>
                            <input type="text" name="search" class="form-control"
                                   placeholder="Search by title or description..."
                                   value="@ViewBag.CurrentSearch" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Filter by Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All Categories</option>
                            @foreach (var cat in ViewBag.Categories as List<SimpleWebsite.Models.Categories>)
                            {
                                var isSelected = ViewBag.CurrentCategory != null &&
                                (int)ViewBag.CurrentCategory == cat.CategoryId;
                                <option value="@cat.CategoryId" selected="@isSelected">
                                    @cat.Name
                                </option>
                            }
                        </select>   
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ti ti-filter me-1"></i>Filter
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Category Pills -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <a asp-action="Index" class="btn btn-sm @(ViewBag.CurrentCategory == null ? "btn-primary" : "btn-outline-primary")">
            All
        </a>
        @foreach (var cat in ViewBag.Categories as List<SimpleWebsite.Models.Categories>)
        {
            <a asp-action="Index" asp-route-categoryId="@cat.CategoryId"
               asp-route-search="@ViewBag.CurrentSearch"
               class="btn btn-sm @(ViewBag.CurrentCategory == cat.CategoryId ? "btn-primary" : "btn-outline-primary")">
                <i class="@cat.Icon me-1"></i>@cat.Name
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- Results Count -->
    <p class="text-muted mb-3">
        Showing <strong>@Model.Count()</strong> courses
        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string))
        {
            <span> for "<strong>@ViewBag.CurrentSearch</strong>"</span>
        }
    </p>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="ti ti-search fs-1 text-muted"></i>
                <h5 class="mt-3 text-muted">No courses found.</h5>
                <a asp-action="Index" class="btn btn-outline-primary mt-2">Clear Filters</a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var course in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100">
                        <img src="@(string.IsNullOrEmpty(course.Thumbnail) ? "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400&h=200&fit=crop" : course.Thumbnail)"
                             class="card-img-top" style="height:200px; object-fit:cover;" />
                        <div class="card-body">
                            @if (course.Category != null)
                            {
                                <span class="badge bg-light-primary text-primary mb-2">
                                    <i class="@course.Category.Icon me-1"></i>@course.Category.Name
                                </span>
                            }
                            <h5 class="card-title fw-semibold">@course.Title</h5>
                            <p class="text-muted small mb-2">
                                <i class="ti ti-user me-1"></i>@course.Instructor?.Fullname
                            </p>
                            <p class="text-muted small">
                                @(course.Description.Length > 100 ? course.Description.Substring(0, 100) + "..." : course.Description)
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary fs-5">
                                @(course.Price == 0 ? "Free" : "$" + course.Price.ToString("0.00"))
                            </span>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-light-primary text-primary">
                                    <i class="ti ti-video me-1"></i>@course.Lessons.Count Lessons
                                </span>
                                <a asp-action="Details" asp-route-id="@course.CourseId"
                                   class="btn btn-primary btn-sm">View</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>