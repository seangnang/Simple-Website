@model IEnumerable<SimpleWebsite.Models.Enrollment>
@{
    ViewData["Title"] = "My Courses";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none position-relative overflow-hidden mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">My Learning</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">My Courses</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="ti ti-book fs-1 text-muted"></i>
                <h5 class="mt-3 text-muted">You haven't enrolled in any courses yet.</h5>
                <a asp-action="Index" class="btn btn-primary mt-3">Browse Courses</a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var enrollment in Model)
            {
                int total = enrollment.Course?.Lessons.Count ?? 0;
                int completed = enrollment.LessonProgresses.Count;
                int percent = total > 0 ? (completed * 100 / total) : 0;

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100">
                        <img src="@(string.IsNullOrEmpty(enrollment.Course?.Thumbnail) ? "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400&h=200&fit=crop" : enrollment.Course.Thumbnail)"
                             class="card-img-top" style="height:180px; object-fit:cover;" />
                        <div class="card-body">
                            <h5 class="fw-semibold">@enrollment.Course?.Title</h5>
                            <p class="text-muted small mb-3">
                                <i class="ti ti-calendar me-1"></i>
                                Enrolled: @enrollment.EnrolledAt.ToString("MMM dd, yyyy")
                            </p>

                            <!-- Progress -->
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-semibold">Progress</small>
                                <small class="text-muted">@completed/@total lessons</small>
                            </div>
                            <div class="progress mb-3" style="height:8px;">
                                <div class="progress-bar bg-primary" style="width:@percent%"></div>
                            </div>

                            @if (enrollment.IsCompleted)
                            {
                                <span class="badge bg-success mb-2">
                                    <i class="ti ti-trophy me-1"></i>Completed!
                                </span>
                            }
                        </div>
                        <div class="card-footer">
                            <a asp-action="Learn" asp-route-id="@enrollment.CourseId"
                               class="btn btn-primary w-100">
                                <i class="ti ti-player-play me-2"></i>
                                @(percent == 0 ? "Start Learning" : "Continue Learning")
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>