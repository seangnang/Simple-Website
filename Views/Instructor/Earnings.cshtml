@{
    ViewData["Title"] = "Earnings";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-1">Earnings Overview</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active">Earnings</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-success rounded">
                        <i class="ti ti-cash fs-4 text-success"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Total Earnings</p>
                        <h4 class="fw-bold mb-0 text-success">
                            $@((ViewBag.TotalEarnings as decimal? ?? 0).ToString("0.00"))
                        </h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-primary rounded">
                        <i class="ti ti-users fs-4 text-primary"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Total Students</p>
                        <h4 class="fw-bold mb-0">@ViewBag.TotalStudents</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="p-3 bg-light-warning rounded">
                        <i class="ti ti-book fs-4 text-warning"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-0 small">Total Courses</p>
                        <h4 class="fw-bold mb-0">@ViewBag.TotalCourses</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Earnings Table -->
    <div class="card">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">
                <i class="ti ti-report-money me-2"></i>Earnings Per Course
            </h6>
            @{
                var earnings = ViewBag.Earnings as dynamic;
            }
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Course</th>
                        <th>Price</th>
                        <th>Students</th>
                        <th>Lessons</th>
                        <th>Status</th>
                        <th>Total Earned</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Earnings)
                    {
                        <tr>
                            <td class="fw-semibold">@item.CourseTitle</td>
                            <td>
                                @if (item.Price == 0)
                                {
                                    <span class="badge bg-success">Free</span>
                                }
                                else
                                {
                                    <span>$@item.Price.ToString("0.00")</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-light-primary text-primary">
                                    <i class="ti ti-users me-1"></i>@item.Students
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-light-warning text-warning">
                                    <i class="ti ti-video me-1"></i>@item.Lessons
                                </span>
                            </td>
                            <td>
                                @if (item.IsPublished)
                                {
                                    <span class="badge bg-success">Published</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Draft</span>
                                }
                            </td>
                            <td class="fw-bold text-success">
                                $@item.Total.ToString("0.00")
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="5" class="fw-bold text-end">Total:</td>
                        <td class="fw-bold text-success fs-5">
                            $@((ViewBag.TotalEarnings as decimal? ?? 0).ToString("0.00"))
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>