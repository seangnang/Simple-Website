@model IEnumerable<SimpleWebsite.Models.Course>
@{
    ViewData["Title"] = "My Courses";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <div class="row align-items-center">
                <div class="col-9">
                    <h4 class="fw-semibold mb-1">My Courses</h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                            <li class="breadcrumb-item active">My Courses</li>
                        </ol>
                    </nav>
                </div>
                <div class="col-3 text-end">
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="ti ti-plus me-1"></i>New Course
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="ti ti-book fs-1 text-muted"></i>
                <h5 class="mt-3 text-muted">You haven't created any courses yet.</h5>
                <a asp-action="Create" class="btn btn-primary mt-3">Create Your First Course</a>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Lessons</th>
                            <th>Students</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(course.Thumbnail) ? "https://placehold.co/50x50?text=C" : course.Thumbnail)"
                                             width="50" height="50" style="object-fit:cover; border-radius:8px;" />
                                        <div>
                                            <p class="mb-0 fw-semibold">@course.Title</p>
                                            <small class="text-muted">@course.CreatedAt.ToString("MMM dd, yyyy")</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge bg-light-primary text-primary">@course.Lessons.Count</span></td>
                                <td><span class="badge bg-light-success text-success">@course.Enrollments.Count</span></td>
                                <td class="fw-semibold">@(course.Price == 0 ? "Free" : "$" + course.Price.ToString("0.00"))</td>
                                <td>
                                    @if (course.IsPublished)
                                    {
                                        <span class="badge bg-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Draft</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Lessons" asp-route-courseId="@course.CourseId"
                                           class="btn btn-sm btn-outline-primary" title="Manage Lessons">
                                            <i class="ti ti-list"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@course.CourseId"
                                           class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="ti ti-edit"></i>
                                        </a>
                                        <form asp-action="TogglePublish" method="post" style="display:inline">
                                            <input type="hidden" name="id" value="@course.CourseId" />
                                            <button type="submit" class="btn btn-sm btn-outline-info" title="Toggle Publish">
                                                <i class="ti ti-@(course.IsPublished ? "eye-off" : "eye")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Delete" method="post" style="display:inline"
                                              onsubmit="return confirm('Delete this course?')">
                                            <input type="hidden" name="id" value="@course.CourseId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="ti ti-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>