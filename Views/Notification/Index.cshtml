@model IEnumerable<SimpleWebsite.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="card bg-light-info shadow-none mb-4">
        <div class="card-body px-4 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="fw-semibold mb-1">
                        <i class="ti ti-bell me-2"></i>Notifications
                    </h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="breadcrumb-item active">Notifications</li>
                        </ol>
                    </nav>
                </div>
                <div class="d-flex gap-2">
                    <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">
                        @Model.Count() Total
                    </span>
                    <span class="badge bg-danger rounded-pill px-3 py-2 fs-6">
                        @Model.Count(n => !n.IsRead) Unread
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="rounded-circle bg-light-primary d-inline-flex align-items-center
                                    justify-content-center mb-3"
                         style="width:80px; height:80px;">
                        <i class="ti ti-bell-off text-primary" style="font-size:2rem;"></i>
                    </div>
                    <h5 class="text-muted">No notifications yet</h5>
                    <p class="text-muted small">You'll see notifications here when something happens</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var notification in Model)
                    {
                        <a href="@(string.IsNullOrEmpty(notification.Link) ? "#" : notification.Link)"
                           class="list-group-item list-group-item-action d-flex align-items-center gap-3 p-4
                                          @(!notification.IsRead ? "border-start border-4 border-primary" : "")"
                           style="transition: background 0.2s;">

                            <!-- Icon -->
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:48px; height:48px;
                                                background: @(!notification.IsRead ? "linear-gradient(135deg,#4f46e5,#7c3aed)" : "#f1f5f9")">
                                <i class="ti ti-bell" style="color: @(!notification.IsRead ? "white" : "#94a3b8"); font-size:1.2rem;"></i>
                            </div>

                            <!-- Content -->
                            <div class="flex-grow-1">
                                <p class="mb-1 @(!notification.IsRead ? "fw-semibold" : "text-muted")">
                                    @notification.Message
                                </p>
                                <small class="text-muted">
                                    <i class="ti ti-clock me-1"></i>
                                    @{
                                        var diff = DateTime.UtcNow - notification.CreatedAt;
                                        string timeAgo;
                                        if (diff.TotalMinutes < 1)
                                            timeAgo = "Just now";
                                        else if (diff.TotalMinutes < 60)
                                            timeAgo = $"{(int)diff.TotalMinutes} min ago";
                                        else if (diff.TotalHours < 24)
                                            timeAgo = $"{(int)diff.TotalHours} hours ago";
                                        else
                                            timeAgo = notification.CreatedAt.ToString("MMM dd, yyyy hh:mm tt");
                                    }
                                    @timeAgo
                                </small>
                            </div>

                            <!-- Badge -->
                            <div class="flex-shrink-0">
                                @if (!notification.IsRead)
                                {
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background:linear-gradient(135deg,#4f46e5,#7c3aed); color:white;">
                                        New
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted rounded-pill px-3 py-2">
                                        Read
                                    </span>
                                }
                            </div>

                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>